<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CyberShop Demo</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <header>
        <h1>CyberShop Demo</h1>
        <nav>
            <a href="#">Home</a>
            <a href="#">Products</a>
            <a href="#">Contact</a>
        </nav>
    </header>

    <main>
        <section class="products">
            <div class="product">
                <h2>Gaming Mouse</h2>
                <p>High precision gaming mouse with RGB lighting</p>
                <span class="price">€49.99</span>
                <button>Add to Cart</button>
            </div>

            <div class="product">
                <h2>Mechanical Keyboard</h2>
                <p>RGB backlit mechanical keyboard</p>
                <span class="price">€89.99</span>
                <button>Add to Cart</button>
            </div>

            <div class="product">
                <h2>Gaming Headset</h2>
                <p>Surround sound headset with mic</p>
                <span class="price">€69.99</span>
                <button>Add to Cart</button>
            </div>
        </section>
    </main>

    <footer>
        <p>© 2026 CyberShop Demo</p>
    </footer>
</body>
</html>
